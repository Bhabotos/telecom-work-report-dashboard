{
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api/auth/$1"
    },
    {
      "source": "/meta",
      "destination": "/api/meta"
    },
    {
      "source": "/dashboard",
      "destination": "/api/dashboard"
    },
    {
      "source": "/reports/daily/(.*)",
      "destination": "/api/reports-daily"
    },
    {
      "source": "/reports/monthly/(.*)",
      "destination": "/api/reports-monthly"
    },
    {
      "source": "/reports/(.*)",
      "destination": "/api/reports"
    },
    {
      "source": "/reports",
      "destination": "/api/reports"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}