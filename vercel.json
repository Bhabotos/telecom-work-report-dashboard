{
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api/auth/$1"
    },
    {
      "source": "/meta",
      "destination": "/api/index"
    },
    {
      "source": "/dashboard",
      "destination": "/api/index"
    },
    {
      "source": "/reports/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}