{
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "/api/auth/:path*"
    },
    {
      "source": "/meta",
      "destination": "/api/mock?route=meta"
    },
    {
      "source": "/dashboard",
      "destination": "/api/mock?route=dashboard"
    },
    {
      "source": "/reports/daily/:date",
      "destination": "/api/mock?route=reports-daily"
    },
    {
      "source": "/reports/monthly/:month",
      "destination": "/api/mock?route=reports-monthly"
    },
    {
      "source": "/reports/:path*",
      "destination": "/api/mock?route=reports"
    },
    {
      "source": "/reports",
      "destination": "/api/mock?route=reports"
    },
    {
      "source": "/master/:path*",
      "destination": "/api/mock?route=master"
    },
    {
      "source": "/users",
      "destination": "/api/mock?route=users"
    },
    {
      "source": "/export/:path*",
      "destination": "/api/mock?route=export"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}